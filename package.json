{
  "name": "@bredbox/n8n-nodes-bredbox",
  "version": "1.0.3",
  "description": "n8n community node for interacting with the Bredbox API",
  "author": {
    "name": "Nicholas C. Zakas",
    "email": "nicholas+npm@humanwhocodes.com"
  },
  "license": "MIT",
  "homepage": "https://bredbox.app",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "n8n-community-node-package",
    "bredbox"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/bredbox-app/n8n-nodes-bredbox.git"
  },
  "scripts": {
    "generate": "node ./scripts/generate.mjs",
    "build": "n8n-node build",
    "build:watch": "tsc --watch",
    "setup:hooks": "node ./scripts/install-hooks.mjs",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "release": "n8n-node release"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": true,
    "credentials": [
      "dist/credentials/BredboxApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Bredbox/Bredbox.node.js"
    ]
  },
  "devDependencies": {
    "@n8n/node-cli": "*",
    "eslint": "9.32.0",
    "prettier": "3.6.2",
    "typescript": "5.9.2"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
